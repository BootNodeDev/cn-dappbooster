# Canton dApp Booster local Splice stack. Copy to .env before starting.

COMPOSE_PROJECT_NAME=canton-barebones

# Selects canton-barebones/config/environments/<name>.json.
CANTON_ENVIRONMENT=localnet

# LocalNet secret for the self-signed auth recipe in config/environments/localnet.json.
CANTON_AUTH_SECRET=unsafe

# DevNet/TestNet OAuth secrets. Public endpoints live in config/environments/*.json.
# CANTON_OAUTH_CLIENT_ID=
# CANTON_OAUTH_CLIENT_SECRET=

# Static token secret when the selected environment uses static-token auth.
# CANTON_AUTH_TOKEN=
