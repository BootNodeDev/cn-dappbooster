# Standalone wallet-gateway-devkit config. Runtime endpoints are selected by
# CANTON_ENVIRONMENT from ../../config/environments.

CANTON_ENVIRONMENT=localnet
CANTON_AUTH_SECRET=unsafe

# Required only when the selected environment uses OAuth.
# CANTON_OAUTH_CLIENT_ID=
# CANTON_OAUTH_CLIENT_SECRET=

# Required only when the selected environment uses static-token auth.
# CANTON_AUTH_TOKEN=

# Use a custom environment config directory for direct host runs.
# CANTON_ENVIRONMENT_CONFIG_DIR=../../config/environments
