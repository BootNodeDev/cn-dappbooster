{
  "name": "@canton-dappbooster/canton-barebones",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "up": "./scripts/up.sh",
    "down": "./scripts/down.sh",
    "wallet-service:fivenorth": "docker compose --env-file .env.fivenorth -f docker-compose.wallet-service.yaml up -d --build",
    "wallet-service:fivenorth:down": "docker compose --env-file .env.fivenorth -f docker-compose.wallet-service.yaml down",
    "health": "./scripts/health-check.sh",
    "token": "node ./scripts/mint-token.mjs",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "node --test",
    "wallet-service:logs": "docker compose logs -f wallet-service"
  }
}
