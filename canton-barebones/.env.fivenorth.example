# Copy to .env.fivenorth and set the FiveNorth client secret.

COMPOSE_PROJECT_NAME=canton-barebones-wallet-service

FIVENORTH_AUTH_URL=https://auth.sandbox.fivenorth.io/application/o/token/
FIVENORTH_CLIENT_ID=validator-devnet-m2m
FIVENORTH_CLIENT_SECRET=paste-client-secret-here
FIVENORTH_SCOPE=daml_ledger_api

CANTON_JSON_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
SPLICE_VALIDATOR_URL=https://wallet.validator.devnet.sandbox.fivenorth.io/api/validator
SPLICE_REGISTRY_API_URL=https://wallet.validator.devnet.sandbox.fivenorth.io/api/validator/v0/scan-proxy

WALLET_SERVICE_PORT=3010
WALLET_SERVICE_CORS_ORIGINS=http://localhost:3011
NETWORK=canton:fivenorth-devnet
WALLET_PROVIDER_ID=wallet-service
WALLET_PROVIDER_VERSION=0.1.0
WALLET_PROVIDER_URL=http://localhost:3010
WALLET_PROVIDER_USER_URL=http://localhost:3010
