# Copy to .env.fivenorth and paste the hackathon bearer token below.

COMPOSE_PROJECT_NAME=canton-barebones-wallet-service

CANTON_JSON_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
CANTON_BACKEND_TOKEN=paste-bearer-token-here-without-the-Bearer-prefix
CANTON_ADMIN_USER_ID=wallet-service

WALLET_SERVICE_PORT=3010
WALLET_SERVICE_CORS_ORIGINS=http://localhost:3011
NETWORK=canton:fivenorth-devnet
WALLET_PROVIDER_ID=wallet-service
WALLET_PROVIDER_VERSION=0.1.0
WALLET_PROVIDER_URL=http://localhost:3010
WALLET_PROVIDER_USER_URL=http://localhost:3010
