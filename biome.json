{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "carpincho-wallet/**",
      "canton-connect-kit/**",
      "dapp/frontend/**",
      "dapp/e2e/**",
      "canton-barebones/**",
      "!**/api-specs",
      "!**/routeTree.gen.ts"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["carpincho-wallet/**"],
      "formatter": {
        "attributePosition": "multiline"
      },
      "css": {
        "parser": {
          "cssModules": false,
          "tailwindDirectives": true
        }
      },
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["./**", "../**"],
                    "message": "Use the '@/' alias instead of relative imports."
                  },
                  {
                    "group": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
                    "message": "Do not include the file extension in imports."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["dapp/frontend/**"],
      "css": {
        "parser": {
          "cssModules": false,
          "tailwindDirectives": true
        }
      },
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "canton-connect-kit/**",
        "dapp/frontend/src/**",
        "!dapp/frontend/src/**/*.test.ts",
        "!dapp/frontend/src/**/*.test.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
                    "message": "Do not include the file extension in imports."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["dapp/e2e/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noEmptyPattern": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["canton-barebones/wallet-service/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ]
}
