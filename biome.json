{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "carpincho-wallet/**",
      "canton-connect-kit/**",
      "counter/frontend/**",
      "!**/node_modules",
      "!**/dist",
      "!**/dist-extension"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["carpincho-wallet/**"],
      "formatter": {
        "attributePosition": "multiline"
      },
      "css": {
        "parser": {
          "cssModules": false,
          "tailwindDirectives": true
        }
      },
      "linter": {
        "rules": {
          "correctness": {
            "useImportExtensions": {
              "level": "error",
              "options": { "forceJsExtensions": false }
            }
          },
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["./**", "../**"],
                    "message": "Use the '@/' alias instead of relative imports."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["counter/frontend/**"],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    }
  ]
}
