{
  "name": "cn-dappbooster",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "canton-connect-kit",
    "carpincho-wallet",
    "canton-barebones",
    "canton-barebones/wallet-gateway-devkit",
    "dapp/daml",
    "dapp/e2e",
    "dapp/frontend"
  ],
  "scripts": {
    "canton:up": "npm --prefix canton-barebones run up --",
    "canton:down": "npm --prefix canton-barebones run down",
    "carpincho:build:extension": "npm --prefix carpincho-wallet run build:extension",
    "app:dev": "npm --prefix dapp/frontend run dev -- --host localhost --port 3012 --strictPort",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "overrides": {
    "@canton-network/dapp-sdk": "1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
