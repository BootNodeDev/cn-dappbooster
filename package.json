{
  "name": "canton-counter-scaffold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "canton:up": "npm --prefix canton-base run up",
    "canton:down": "npm --prefix canton-base run down",
    "canton:health": "npm --prefix canton-base run health",
    "canton:token": "npm --prefix canton-base run token",
    "build-dar": "bash scripts/build-dar.sh",
    "deploy-dar": "bash canton-base/scripts/deploy-dar.sh",
    "wallet-service:dev": "npm --prefix counter/wallet-service run dev",
    "carpincho:build:extension": "npm --prefix carpincho-wallet run build:extension",
    "app:dev": "npm --prefix counter/frontend run dev -- --host localhost --port 3012 --strictPort",
    "e2e": "npm --prefix e2e test",
    "e2e:headed": "npm --prefix e2e run test:headed",
    "e2e:ui": "npm --prefix e2e run test:ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
