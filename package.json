{
  "name": "cn-dappbooster",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "canton-connect-kit",
    "carpincho-wallet",
    "canton-barebones",
    "canton-barebones/wallet-gateway-devkit",
    "dapp/daml",
    "dapp/e2e",
    "dapp/frontend"
  ],
  "scripts": {
    "canton:up": "npm --prefix canton-barebones run up",
    "localnet:wallet-gateway:up": "npm --prefix canton-barebones run up:wallet-gateway",
    "localnet:wallet-gateway-devkit:up": "npm --prefix canton-barebones run up:wallet-gateway-devkit",
    "canton:down": "npm --prefix canton-barebones run down",
    "canton:health": "npm --prefix canton-barebones run health",
    "canton:token": "npm --prefix canton-barebones run token",
    "build-dar": "bash scripts/build-dar.sh",
    "deploy-dar": "bash canton-barebones/scripts/deploy-dar.sh",
    "wallet:dev": "npm --prefix carpincho-wallet run dev",
    "wallet-gateway-devkit:dev": "npm --prefix canton-barebones/wallet-gateway-devkit run dev",
    "wallet-gateway-devkit:health": "curl -fsS http://localhost:3010/health",
    "wallet-service:dev": "npm run wallet-gateway-devkit:dev",
    "wallet-service:health": "npm run wallet-gateway-devkit:health",
    "carpincho:build:extension": "npm --prefix carpincho-wallet run build:extension",
    "app:dev": "npm --prefix dapp/frontend run dev -- --host localhost --port 3012 --strictPort",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "e2e": "npm --prefix dapp/e2e test",
    "e2e:headed": "npm --prefix dapp/e2e run test:headed",
    "e2e:ui": "npm --prefix dapp/e2e run test:ui",
    "prepare": "husky"
  },
  "overrides": {
    "@canton-network/dapp-sdk": "1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
