{
  "manifest_version": 3,
  "name": "Carpincho Wallet",
  "description": "Local Canton wallet for development.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/carpincho-16.png",
    "32": "icons/carpincho-32.png",
    "48": "icons/carpincho-48.png",
    "128": "icons/carpincho-128.png"
  },
  "action": {
    "default_title": "Carpincho Wallet",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/carpincho-16.png",
      "32": "icons/carpincho-32.png",
      "48": "icons/carpincho-48.png",
      "128": "icons/carpincho-128.png"
    }
  },
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*"
  ]
}
