# Copy to .env.local and fill in. All optional — sensible defaults apply.

# CIP-0103 network id passed to the wallet connector. Defaults to 'canton:local'.
VITE_CANTON_NETWORK=canton:local

# WalletConnect (Reown) project id. Required ONLY for the WalletConnect connect
# path (carpincho web app). The Carpincho browser extension needs no project id.
# Leave unset to hide the WalletConnect CTA and connect via the extension only.
VITE_WC_PROJECT_ID=
